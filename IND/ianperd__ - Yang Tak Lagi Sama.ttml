  <body dur="05:03.893">
    <div begin="00:17.771" end="05:03.893">
      <p begin="00:17.771" end="00:20.843" ttm:agent="v1" itunes:key="L1">
        <span begin="00:17.771" end="00:20.843">Dulu kita pulang terlambat</span>
      </p>
      <p begin="00:21.603" end="00:26.011" ttm:agent="v1" itunes:key="L2">
        <span begin="00:21.603" end="00:26.011">Tertawa pada hal sepele</span>
      </p>
      <p begin="00:27.193" end="00:29.231" ttm:agent="v1" itunes:key="L3">
        <span begin="00:27.193" end="00:29.231">Kopi dingin</span>
      </p>
      <p begin="00:31.471" end="00:34.721" ttm:agent="v1" itunes:key="L4">
        <span begin="00:31.471" end="00:34.721">Hujan di jendela</span>
      </p>
      <p begin="00:35.441" end="00:40.022" ttm:agent="v1" itunes:key="L5">
        <span begin="00:35.441" end="00:40.022">Semua terasa rumah</span>
      </p>
      <p begin="00:42.243" end="00:46.923" ttm:agent="v1" itunes:key="L6">
        <span begin="00:42.243" end="00:46.923">Kini meja yang sama terasa asing</span>
      </p>
      <p begin="00:47.953" end="00:49.088" ttm:agent="v1" itunes:key="L7">
        <span begin="00:47.953" end="00:49.088">Kau di depan</span>
      </p>
      <p begin="00:49.088" end="00:53.056" ttm:agent="v1" itunes:key="L8">
        <span begin="00:49.088" end="00:53.056">Tapi jauh sekali</span>
      </p>
      <p begin="00:56.120" end="01:01.189" ttm:agent="v1" itunes:key="L9">
        <span begin="00:56.120" end="01:01.189">Kata-kataku jatuh di antara</span>
      </p>
      <p begin="01:01.480" end="01:07.216" ttm:agent="v1" itunes:key="L10">
        <span begin="01:01.480" end="01:07.216">Tatapan yang kau alihkan</span>
      </p>
      <p begin="01:08.120" end="01:11.600" ttm:agent="v1" itunes:key="L11">
        <span begin="01:08.120" end="01:11.600">Mengapa yang hangat</span>
      </p>
      <p begin="01:12.000" end="01:15.880" ttm:agent="v1" itunes:key="L12">
        <span begin="01:12.000" end="01:15.880">Kini terasa bukan aku lagi</span>
      </p>
      <p begin="01:16.229" end="01:18.688" ttm:agent="v1" itunes:key="L13">
        <span begin="01:16.229" end="01:18.688">Aku sudah jujur</span>
      </p>
      <p begin="01:18.919" end="01:22.818" ttm:agent="v1" itunes:key="L14">
        <span begin="01:18.919" end="01:22.818">Tapi kau tetap tak mengerti</span>
      </p>
      <p begin="01:24.138" end="01:26.967" ttm:agent="v1" itunes:key="L15">
        <span begin="01:24.138" end="01:26.967">Kau yang dulu kucari</span>
      </p>
      <p begin="01:26.967" end="01:30.788" ttm:agent="v1" itunes:key="L16">
        <span begin="01:26.967" end="01:30.788">Yang tak pernah bisa terganti</span>
      </p>
      <p begin="01:31.058" end="01:34.797" ttm:agent="v1" itunes:key="L17">
        <span begin="01:31.058" end="01:34.797">Kini di sampingku</span>
      </p>
      <p begin="01:35.007" end="01:39.589" ttm:agent="v1" itunes:key="L18">
        <span begin="01:35.007" end="01:39.589">Namun rasanya tak lagi sama</span>
      </p>
      <p begin="01:43.239" end="01:46.487" ttm:agent="v1" itunes:key="L19">
        <span begin="01:43.239" end="01:46.487">Aku hafal nada napasmu</span>
      </p>
      <p begin="01:46.839" end="01:50.138" ttm:agent="v1" itunes:key="L20">
        <span begin="01:46.839" end="01:50.138">Tapi kini sulit terbaca</span>
      </p>
      <p begin="01:51.086" end="01:55.298" ttm:agent="v1" itunes:key="L21">
        <span begin="01:51.086" end="01:55.298">Kau bilang kau “baik-baik saja”</span>
