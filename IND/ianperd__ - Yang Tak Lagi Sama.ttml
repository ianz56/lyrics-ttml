      <p begin="01:57.039" end="02:05.418" ttm:agent="v1" itunes:key="L22">
        <span begin="01:57.039" end="02:05.418">Tapi senyummu tak sampai mata</span>
      </p>
      <p begin="02:06.559" end="02:12.606" ttm:agent="v1" itunes:key="L23">
        <span begin="02:06.559" end="02:12.606">Aku rindu diam dalam pelukan</span>
      </p>
      <p begin="02:13.498" end="02:18.908" ttm:agent="v1" itunes:key="L24">
        <span begin="02:13.498" end="02:18.908">Rindu ribut kecil lalu berdamai</span>
